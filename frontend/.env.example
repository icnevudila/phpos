# Backend API — çalışan backend ile aynı host/port olmalı (backend/.env içindeki PORT + API_PREFIX).
# Örnek: PORT=4010 ve API_PREFIX=/api ise → http://localhost:4010/api
VITE_API_URL="http://localhost:4000/api"

# Landing "Patient portal" linki: /{slug}/portal/login (seed örnek: iloilo-demo)
VITE_PORTAL_DEMO_SLUG="iloilo-demo"

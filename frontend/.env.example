# Backend API — çalışan backend ile aynı host/port olmalı (backend/.env içindeki PORT + API_PREFIX).
# Örnek: PORT=4010 ve API_PREFIX=/api ise → http://localhost:4010/api
# Yerel dev (backend PORT=4010): http://localhost:4010/api
VITE_API_URL="http://localhost:4010/api"

# Landing "Patient portal" linki: /{slug}/portal/login (seed örnek: iloilo-demo)
VITE_PORTAL_DEMO_SLUG="iloilo-demo"

# Lobby TV URL (must match backend PUBLIC_QUEUE_DISPLAY_TOKEN)
# VITE_PUBLIC_QUEUE_DISPLAY_TOKEN="your-display-token"

# Playwright authenticated e2e (optional — yoksa auth testleri skip edilir)
# E2E_EMAIL="admin@clinic.test"
# E2E_PASSWORD="your-password"
# E2E_PATIENT_ID="uuid-of-existing-patient"

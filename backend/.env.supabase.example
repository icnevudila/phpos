# Supabase Postgres (Prisma)
# Production icin pooler URL onerilir.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# API
NODE_ENV="production"
PORT=4000
API_PREFIX="/api"
APP_PUBLIC_URL="https://your-frontend-domain.vercel.app"

# JWT
JWT_ACCESS_SECRET="change-me-access-min-32-chars-long-secret"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-long-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# CORS
CORS_ORIGIN="https://your-frontend-domain.vercel.app"

# PayMongo
PAYMONGO_SECRET_KEY=""
PAYMONGO_WEBHOOK_SECRET=""

# Security
ALLOW_PUBLIC_REGISTER="false"

# Optional: Supabase Storage
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="patient-files"

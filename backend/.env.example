# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dentease_ph?schema=public"

# API
NODE_ENV="development"
PORT=4000
API_PREFIX="/api"

# Staff uygulamasının public kökü (PayMongo mock redirect, şifre sıfırlama redirect)
APP_PUBLIC_URL="http://localhost:5173"
# Şifre sıfırlama istek limiti (saat başına / IP)
# AUTH_FORGOT_RATE_LIMIT_MAX=5

# PayMongo secret (Dashboard → API keys; sk_live_ / sk_test_)
PAYMONGO_SECRET_KEY=""

# Portal hasta JWT (yoksa JWT_ACCESS_SECRET ile imzalanır)
# PORTAL_JWT_SECRET=""
# PORTAL_JWT_EXPIRES="30d"
# Portal dosya indirme HMAC token (yoksa PORTAL_JWT_SECRET / JWT_ACCESS_SECRET)
# PORTAL_FILE_TOKEN_SECRET=""
# PORTAL_FILE_TOKEN_TTL_SEC=300
# Signed URL tam kök (yoksa istek Host başlığı)
# API_PUBLIC_URL="http://localhost:4000"

# SMS (Semaphore) — yoksa SMS gönderimi atlanır / dev mesajı
# SEMAPHORE_API_KEY=""
# SEMAPHORE_SENDER="DentEase"

# SMS zamanlayıcıyı kapatmak için: "1"
# DISABLE_SMS_CRON=""

# Gün sonu Z-raporu PDF e-postası (20:00 Asia/Manila) — kapatmak için: "1"
# DISABLE_EOD_EMAIL_CRON=""
# Test: tüm kliniklerde tek alıcıya gönder
# EOD_EMAIL_OVERRIDE="admin@example.com"

# Email (Resend) — yoksa e-posta dry-run modunda loglanır
# Resend dashboard → API Keys: re_...
# RESEND_API_KEY=""
# Gönderici adres (Resend'de doğrulanmış domain kullanın)
# RESEND_FROM_EMAIL="noreply@dentease.ph"


# Güvenlik (GAP-003)
# /auth/register yalnızca "true" iken açılır. Prod’da false bırakın; ilk yerel kurulumda true yapın.
ALLOW_PUBLIC_REGISTER="false"

# Dashboard KPI/charts/alerts önbellek (saniye; kapatmak için DISABLE_DASHBOARD_CACHE=1)
# DASHBOARD_CACHE_TTL_SEC=60

# Genel API rate limit (/api altı)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=500

# Auth login/register ek sıkı limit
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=30

# PayMongo webhook (Dashboard → Webhook secret, whsk_...)
# Production'da zorunlu; imza: Paymongo-Signature header
PAYMONGO_WEBHOOK_SECRET=""

# JWT (Modül 2'de kullanılacak)
JWT_ACCESS_SECRET="change-me-access-min-32-chars-long-secret"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-long-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# CORS (Vercel frontend URL). Production’da zorunlu: boş bırakılırsa tarayıcı CORS alamaz (uyarı loglanır).
CORS_ORIGIN="http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# Lobby TV kuyruk ekranı (/queue/display?token=…&clinicId=… veya &slug=…)
# PUBLIC_QUEUE_DISPLAY_TOKEN="change-me-long-random-token"

# Portal OTP — ek limit (SMS / brute-force; /api/portal/auth/*)
# PORTAL_OTP_REQUEST_WINDOW_MS=900000
# PORTAL_OTP_REQUEST_MAX=8
# PORTAL_OTP_VERIFY_WINDOW_MS=900000
# PORTAL_OTP_VERIFY_MAX=30

# Dosya depolama: local | s3 | supabase
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR=""

# STORAGE_DRIVER=s3
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET=""
# S3_PUBLIC_BASE_URL=""

# STORAGE_DRIVER=supabase
# SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET=""
